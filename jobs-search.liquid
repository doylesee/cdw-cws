{%- endcomment -%}
{% include '__global__config__reusable-texts' %}
{% include '/__global__config__variables' %}

{% page_required_header %}

{% capture template_permalink_content_tag %}{{ template.permalink }}-content{% endcapture %}
{{ template_permalink_content_tag | pages_with_tag | assign_to: 'template_permalink_content' }}

{% if params['q'] == blank and params['location'] == blank %}
    {% assign facet_fields_array = "cfml1;cfml2;cfml3;cfml4;cfml5;cfml6;cfml7;cfml8;cfml9;cfml10" | split: ';' | assign_to: 'facet_fields' %}
    {% for facet_field in facet_fields %}
        {% if params[facet_field] != blank %}
            {% capture facet_field_value %}-{{ params[facet_field]  | replace: '/','-' | replace: ' - ','-' | replace: ' ','-' | downcase  }}{% endcapture %}
            {% assign facet_tag = facet_tag | append: facet_field_value | lstrip %}                
        {% endif %}
    {% endfor %}
{% endif %}
{% capture facet_content_tag %}search-{{ facet_tag | remove_first: '-' }}-jobs-content{% endcapture %}
{{ facet_content_tag | pages_with_tag | assign_to: 'facet_content' }}

{% if template_permalink_content.size > 0 %}
    {% capture jobs_category_content_tag %}{{ template_permalink_content_tag }}{% endcapture %}
{% elsif facet_content.size > 0 %}
    {% capture jobs_category_content_tag %}{{ facet_content_tag }}{% endcapture %}
{% else %}
    {% capture jobs_category_content_tag %}search-jobs-content{% endcapture %}
{% endif %}

{{ jobs_category_content_tag | pages_with_tag | assign_to: 'jobs_category_content' }}

{% capture include_name %}{{ site_name }}__{{ jobs_category_content[0].permalink }}__title{% endcapture %}
{% include '/_config__include-logic' %}
{% if include_content != blank %}
    {% capture category_page_title %}{{ include_content }}{% endcapture %}
{% else %}
    {% capture category_page_title %}{{ jobs_category_content[0].title | html_safe }}{% endcapture %}
{% endif %}

<div class="page-details-wrapper">
    <div class="jobs-category-banner">
        {% if jobs_category_content.size > 0 %}
            {% if jobs_category_content[0].images.size > 1 %}
                <img src="{{ jobs_category_content[0].images[1].url }}" alt="{{ category_page_title }}" class="full-width" loading="lazy" />
            {% else %}
                <img src="{{ jobs_category_content[0].images[0].url }}" alt="{{ category_page_title }}" class="full-width" loading="lazy" />
            {% endif %}
        {% endif %}
    </div>
            
    <div class="job-list">

        <div class="jobs-category-section show-for-sr">
            <div class="row">
                <div class="columns">
                    {% if params['saved_jobs'] == '1' %}
                        <h1>{{ text_saved_jobs }}</h1>

                    {% elsif jobs_category_content.size > 0 %}
                        <h1>{{ category_page_title }}</h1>

                        {% capture include_name %}{{ cb_site_type }}__{{ jobs_category_content[0].permalink }}_content{% endcapture %}
                        {% include '/_config__include-logic' %}
                        {% if include_content != blank %}
                            {{ include_content }}
                        {% else %}
                            {{ jobs_category_content[0].content }}
                        {% endif %}

                    {% elsif params['q'] != blank or params['ns_location'] != blank or params['location'] != blank %}
                        <h1>{{ text_search_results_heading }}</h1>

                    {% else %}
                        <h1>{{ text_job_search_results }}</h1>
                        {% if params['ns_inactive_job'] == '1' %}
                            <p>{{ text_inactive_referral_job }}</p>
                        {% endif %}

                    {% endif %}
                </div>
            </div>
        </div><!--close .jobs-category-section-->

        <div class="row">
            {% if jobs.total_entries > 0 and params['saved_jobs'] != '1' %}
                <div class="columns large-3">
                    <div class="facet-section">
                        <section class="space-medium">
                            {% capture has_multiple_facet_options %}false{% endcapture %}
                            <div class="facet-section__heading hide space-large show-for-large">
                                <h2 class="heading-3">{{ text_refine_your_search }}</h2>
                            </div>

                            <div class="facet-section-outer">
                                <button class="facet-filter-results-button heading-3 space-none full-width text-left hide-for-large">{{ text_refine_your_search }}</button>

                                <div class="facet-section-inner">
                                    <!-- Assigning the Facets -->
                                    {% capture facet_fields %}
                                        {{ text_team }}, cfm4_seo, multi, default, 10, 100, expanded;
                                        {{ text_focus_area }}, cfm3_seo, multi, default, 10, 100, expanded;
                                        {{ text_country }}, location_country_seo, single, asc, 10, 100, collapsed;
                                        {{ text_state_province_location }}, location_state_seo, single, asc, 10, 100, collapsed;
                                    {% endcapture %}

                                    {% assign facet_setup = facet_fields | split: ';' | assign_to: 'facet_setup_split'; %}

                                    {% for facet_attrs in facet_setup_split %}
                                        <!-- Setting variables for the Facet attributes -->
                                        {{ facet_attrs | split: ', ' | assign_to: 'facet_attr' }}
                                        {% assign facet_heading = facet_attr[0] %}
                                        {% assign facet_field = facet_attr[1] %}
                                        {% assign facet_type = facet_attr[2] %}
                                        {% assign facet_order = facet_attr[3] %}
                                        {% assign facet_num_display = facet_attr[4] %}
                                        {% assign facet_num_limit = facet_attr[5] %}
                                        {% assign facet_expanded = facet_attr[6] %}

                                        {% capture facet_num_display_int %}{{ facet_num_display }}{% endcapture %}
                                        {% assign facet_num_display_int = facet_num_display_int | times: 1 %}

                                        <!-- Setting the Facets -->
                                        {% if facet_type == "multi" %}
                                            {{ facet_field | facet_multi: facet_num_limit, facet_order | assign_to: 'fa' }}
                                            {% assign facets = fa %}
                                        {% else %}
                                            {{ facet_field | facet_single: facet_num_limit, facet_order | assign_to: 'fa' }}
                                            {% assign facets = fa %}
                                        {% endif %}

                                        {% assign facet_results = facets[facet_field] %}

                                        {{ facet_field | selected_facets_by_name | assign_to: 'fas' }}
                                        {% assign facet_select = fas %}

                                        {% if facet_results.size > 1 or facet_select.size >= 1 %}
                                            {% if has_multiple_facet_options == 'false' %}
                                                <script>$('.facet-section__heading').removeClass('hide');</script>
                                            {% endif %}
                                            {% capture has_multiple_facet_options %}true{% endcapture %}
                                            
                                            {% if facet_select.size >= 1 %}
                                                <!-- Set variable to store Facet option Clear Filter link -->
                                                {% assign clear_filter = "" %}
                                                {% capture clear_filter %}{{ facet_field | get_facet_url_sans }}{% endcapture %}
                                            {% endif %}

                                            <div class="facet-item padded-small{% if facet_select.size < 1 and facet_expanded == 'expanded' %} active{% endif %}">
                                                <div class="facet-item__heading">
                                                    <button class="heading-6 space-none js" aria-expanded="{% if facet_expanded != 'expanded' %}false{% else %}true{% endif %}">{{ facet_heading }} <span class="facet-item__heading-expand-collapse text-right"></span></button>
                                                </div>
                                                <div class="facet-item__options">
                                                    <div class="space-small"></div>
                                                    {% assign facet_num_limit_counter = "0" %}
                                                    {% for facet in facet_results %}
                                                        {% if facet['permalink'] != "" %}

                                                            {% if facet_num_limit_counter == "0" %}
                                                                <div class="facet-item__row">
                                                            {% endif %}

                                                            {% if facet_num_limit_counter == facet_num_display %}
                                                                </div>

                                                                <div><a class="facet-item__show-more js text-small branded-link-no-arrow" ref="{{ facet_field }}" href="javascript: void(0);" rel="nofollow">+ {{ text_view_more }}</a></div>

                                                                <div class="facet-item__row facet-item__row--hidden" id="facet-item__row--{{ facet_field }}">
                                                            {% endif %}

                                                            <div class="facet-item__options-item clearfix padded-v-xsmall">
                                                                <a href="{{ facet['query'] }}" class="heading-6 facet-item__option-link js branded-link-no-arrow"{% if facet_select.size >= 1 %} rel="nofollow"{% endif %}>
                                                                    <span class="facet-item__options-item-type facet-item__options-item-type--{{ facet_type }} {% if facet['is_selected'] == true %}facet-item__options-item-type--selected{% endif %}"></span>
                                                                    <span class="facet-item__option-item-label">{{ facet["label"] }} ({{ facet["count"] }}<span class="show-for-sr">{{ text_jobs }}</span>)</span>
                                                                    <span class="show-for-sr">{% if facet['is_selected'] == true %}{{ text_selected }}{% endif %}</span>
                                                                </a>
                                                            </div>
                                                            {% capture facet_num_limit_counter %}{{ facet_num_limit_counter | plus: '1' }}{% endcapture %}
                                                        {% endif %}

                                                        {% if forloop.last and facet_num_limit_counter != "0" %}
                                                            </div>
                                                        {% endif %}

                                                        <!--Keep select facets after "Show More" open-->
                                                        {% if facet['is_selected'] == true and forloop.index > facet_num_display_int %}
                                                            <script>
                                                                $('.facet-item__show-more.js').addClass('hide');
                                                                $('.facet-item__row--hidden').removeClass('facet-item__row--hidden');
                                                            </script>
                                                        {% endif %}
                                                    {% endfor %}
                                                </div><!--close .facet-item__options-->
                                                {% if facet_select.size >= 1 %}<div class="hide"><a href="{{ clear_filter }}" class="facet-item__heading-clear text-small branded-link-no-arrow" rel="nofollow">{{ text_clear_filters }}</a></div>{% endif %}
                                            </div><!--close .facet-item-->
                                        {% endif %}
                                    {% endfor %}

                                    <div class="text-right padded-v-xsmall"><a href="{{ "cfm1_seo,cfm2_seo,cfm3_seo,cfm4_seo,cfm5_seo,cfm6_seo,cfm7_seo,cfm8_seo,cfm9_seo,job_tags_seo,location_country_seo,location_state_seo,location_city_seo" | get_facet_url_sans }}" rel="nofollow" class="text-small facet-item__option-link js branded-link-no-arrow" style="text-transform: uppercase;">{{ text_clear_all }}</a></div>
                                    {%- comment -%}<div class="padded-v-medium hide-for-large"><a href="javascript:void(0);" class="facet-filter-results-button branded-button branded-button-1" rel="nofollow">{{ text_close }}</a></div>{%- endcomment -%}

                                    <div class="facets-selected">
                                        {% assign facet_setup = facet_fields | split: ';' | assign_to: 'facet_setup_split'; %}
                                        {% for facet_attrs in facet_setup_split %}
                                            <!-- Setting variables for the Facet attributes -->
                                            {{ facet_attrs | split: ', ' | assign_to: 'facet_attr' }}
                                            {% assign facet_field = facet_attr[1] %}
                                            {% assign facet_type = facet_attr[2] %}
                                            {% assign facet_order = facet_attr[3] %}
                                            {% assign facet_num_limit = facet_attr[5] %}

                                            <!-- Setting the Facets -->
                                            {% if facet_type == "multi" %}
                                                {{ facet_field | facet_multi: facet_num_limit, facet_order | assign_to: 'fa' }}
                                                {% assign facets = fa %}
                                            {% else %}
                                                {{ facet_field | facet_single: facet_num_limit, facet_order | assign_to: 'fa' }}
                                                {% assign facets = fa %}
                                            {% endif %}

                                            {% assign facet_results = facets[facet_field] %}

                                            {{ facet_field | selected_facets_by_name | assign_to: 'fas' }}
                                            {% assign facet_select = fas %}

                                            {% for facet in facet_results %}
                                                {% if facet['is_selected'] == true %}
                                                    <a href="{{ facet['query'] }}" class="text-small branded-link-no-arrow">
                                                        {{ facet["label"] }}
                                                        &nbsp;
                                                        <i class="fa-solid fa-circle-xmark"><span class="show-for-sr">remove</span></i>
                                                    </a>
                                                {% endif %}
                                            {% endfor %}
                                        {% endfor %}
                                    </div><!--close .facets-selected-->

                                </div><!--close .facet-section-inner-->
                            </div><!--close .facet-section-outer-->
                        </section>

                        <div class="padded-v-small hide">
                            <p><button class="candidate-notification-link branded-button-medium full-width">{{ text_set_up_job_alerts }}</button></p>
                        </div>
                    </div><!--close .facet-section-->
                </div>
            {% endif %}

            <div class="columns{% if jobs.total_entries > 0 and params['saved_jobs'] != '1' %} large-9{% endif %}">
                <div class="jobs-section__outer">
                    {% if jobs.total_entries > 0 %}
                    <div class="jobs-heading space-large">
                        <div class="row">
                            <div class="columns large-7 space-small">
                                <div class="padded-v-xsmall"></div>
                                {{ text_showing }}
                            </div>
                            <div class="columns large-5 text-right">
                                <div class="padded-v-xsmall"></div>
                                <div class="branded-search branded-search--sort-by clearfix">
                                    <label for="sortby-mobile">{{ text_sort_by }}:</label>
                                    <select id="sortby-mobile" class="sortby-mobile-js" style="display: inline;">
                                        <option value="default"{% if params['sort_by'] == blank or params['sort_by'] == 'default'%} selected{% endif %}>{{ text_relevance }}</option>
                                        <option value="title,asc"{% if params['sort_by'] == 'title,asc'%} selected{% endif %}>{{ text_job_title }} (A-Z)</option>
                                        <option value="title,desc"{% if params['sort_by'] == 'title,desc'%} selected{% endif %}>{{ text_job_title }} (Z-A)</option>
                                        <option value="updated_at,desc"{% if params['sort_by'] == 'updated_at,desc'%} selected{% endif %}>{{ text_most_recent }}</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                    </div><!--close .jobs-heading-->
                    {% endif %}

                    <section>
                        <div class="jobs-section">
                            <div class="hide">
                                {{ notificationlabel | candidate_job_notification_link }}
                            </div>
                            <div class="preloader preloader--search">
                                <div class="facet-jobs-loading hide--- hide-for-print" role="alert" aria-labelledby="facet-jobs-loading">
                                    <div class="show-for-sr"><label id="facet-jobs-loading">{{ text_loading_jobs }}</label></div>
                                </div>
                            </div>
                            <div class="jobs-section__inner">
                                {% if no_results_found %}
                                    <div class="padded-v-small"></div>
                                    {{ text_no_results_found }}
                                {% else %}
                                    <div class="jobs-section__list space-medium">
                                        <div class="facet-jobs-loaded hide--- hide-for-print" role="alert" aria-labelledby="facet-jobs-loaded">
                                            <div class="show-for-sr">
                                                <label id="facet-jobs-loaded">
                                                    {% if jobs.total_entries > 0 %}
                                                        {{ text_showing }}
                                                    {% endif %}
                                                </label>
                                            </div>
                                        </div><!--close .facet-loaded-jobs-->

                                        {% for job in jobs %}
                                            <div class="jobs-section__item" id="{{ job.cfdisplay_JobDisplayID }}">
                                                {% if forloop.index > 1 %}<div class="padded-v-small"></div>{% endif %}
                                                <div class="row">
                                                    <div class="column">
                                                        <h4 class="heading-5 space-xsmall">{{ job | link_to_job }}</h4>

                                                        <div class="row">
                                                            <div class="columns medium-7">
                                                                {{ job.cfm3 }}
                                                            </div>
                                                            <div class="columns medium-5 text-right">
                                                                {% if job.location.city contains 'Remote' or job.location.city contains 'remote' %}
                                                                    Remote - {{ job.location.country | replace: 'United States','USA' }}

                                                                {% else %}
                                                                    {% if job.location.city != blank %}
                                                                        {{ job.location.city }}{% if job.location.state_prov_short != blank or job.location.country != blank %},{% endif %}
                                                                    {% endif %}
                                                                    {% if job.location.state_prov_short != blank %}
                                                                        {% capture job_location_state_prov_short_no_digit %}{{ job.location.state_prov_short | replace_global_regex: "[\d]", ":::" }}{% endcapture %}
                                                                        {% if job_location_state_prov_short_no_digit contains ':::' %}
                                                                            {{ job.location.state_prov }}{% if job.location.country != blank %},{% endif %}
                                                                        {% else %}
                                                                            {{ job.location.state_prov_short }}{% if job.location.country != blank %},{% endif %}
                                                                        {% endif %}
                                                                    {% endif %}
                                                                    {% if job.location.country != blank %}{{ job.location.country }}{% endif %}

                                                                {% endif %}
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="padded-v-small"></div>
                                            </div>  
                                        {% endfor %}
                                    </div><!--close .jobs-section__list-->
                                    <div class="jobs-section__paginate text-center">
                                        <a href="{{ request_fullpath }}{% if request_fullpath contains '?' %}&{% else %}?{% endif %}page=2" class="jobs-section__paginate-view-more" rel="nofollow">{{ text_view_more_jobs }}</a>

                                        {% capture previous_arrow %}><i class="fa-solid fa-chevron-left"><span class="show-for-sr">{{ text_previous }}</span></i><{% endcapture %}
                                        {% capture next_arrow %}><i class="fa-solid fa-chevron-right"><span class="show-for-sr">{{ text_next }}</span></i><{% endcapture %}
                                        {{ jobs | paginate | replace: '>previous<',previous_arrow | replace: '>next<',next_arrow }}
                                    </div>
                                {% endif %}
                            </div><!--close .jobs-section__inner-->
                        </div><!--close .jobs-section-->
                    </section>
                </div><!--close .jobs-section__outer-->
            </div>
        </div><!--close .row-->

    </div>
</div><!--close .page-details-wrapper-->
 
{% page_required_footer %}