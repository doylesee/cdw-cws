{% capture page_content_formatted %}{{ page_section_object.content | replace_global_regex: '\r\n','' | replace: '<pre>ITEM ENDITEM START</pre>','</div>------<div class="item">' | replace: '<pre>ITEM START</pre>','---<div class="item">' | replace: '<pre>ITEM END</pre>','</div>------' }}{% endcapture %}
{% assign page_content_array = page_content_formatted | split: '---' | assign_to: 'page_section_elements' %}

{% capture column_contents %}{% endcapture %}
{{ 0 | assign_to: 'item_index' }}
{% assign row_index = 0 %}

{% for page_section_element in page_section_elements %}
	{% if page_section_element contains '<div class="item">' %}
		{% capture column_contents %}
		{{ column_contents }}
		{% if row_index == 0 %}
			<div class="row space-medium">
			{% assign row_index = 1 %}
		{% endif %}
		<div class="columns large-4 end">
			<div class="space-foundation">
				<div class="stat-item same-height-item-js text-center">
					{{ page_section_element }}
				</div>
			</div>
		</div>
		{% endcapture %}
		{{ item_index | plus: 1 | assign_to: 'item_index' }}

	{% elsif page_section_element != '' %}
		{% capture column_contents %}
		{{ column_contents }}
		{% if row_index == 1 %}
			{% assign row_index = 0 %}
			</div>
		{% endif %}
		<div class="row">
			<div class="column">
				{{ page_section_element }}
			</div>
		</div>
		{% endcapture %}

	{% endif %}
{% endfor %}

{% capture column_contents %}
{{ column_contents }}
{% if row_index == 1 %}
	</div>
{% endif %}
{% endcapture %}

<div class="row">
	<div class="column">
		<div class="three-stats-outer space-medium">
			{% if page_section_object.images.size > 0 %}
				<img src="{{ page_section_object.images[0].url }}" alt="{% if page_section_object.images[0].title != page_section_object.images[0].file_name %}{{ page_section_object.images[0].title | html_safe }}{% endif %}" class="full-width the-creature"{% if is_lazyload == 'true' %} loading="lazy"{% endif %} />
			{% endif %}
			<div class="space-medium"></div>
			<div class="row">
				<div class="column small-10 small-offset-1 end">
					{% if page_title != blank %}<h1>{{ page_title }}</h1>{% endif %}
					{{ column_contents }}
				</div>
			</div>
			<div class="space-small"></div>
		</div>
	</div>
</div>