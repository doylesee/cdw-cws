                        </div>
                    </header><!--close header-->
                </div><!--close .header-outer-->
            </div><!--close .top-wrapper-->

            <div id="main" tabindex="-1"></div>
            <div class="template-content{% if params['savejob'] == '1' %} hide{% endif %}" role="main">
                {% unless page.tag_list contains 'no-index' or job or post %}
                <section class="page-banner{% if cb_is_home_page != 'true' %} show-for-large{% endif %}">
                    <div class="row row--wider">
                        <div class="column small-10 end">
                            {{ text_banner_copy }}

                            <div class="page-banner__form show-for-large">
                                <div class="cs_item_type_jobsearch cs_cfix cs_jsearchform">
                                    <form id="search-form--page-banner" method="get" action="/{{ current_locale.locale }}/search/jobs" class="search-form">
                                        <div class="row">
                                            <div class="columns">
                                                <label for="cs_jobsearchforminput_keyword" class="show-for-sr">{{ text_keyword_placeholder }}</label>
                                                <input type="text" placeholder="{{ text_keyword_placeholder }}" id="cs_jobsearchforminput_keyword" class="ui-autocomplete-input" autocomplete="off" name="q" value="{{ params['q'] | escape_html }}"><span role="status" aria-live="polite" class="ui-helper-hidden-accessible"></span>
                                                <input type="submit" value="&#xf002;" class="fontawesome" />
                                            </div>
                                        </div>
