                                                    <li class="show-for-large with-separator"><a href="/{{ current_locale.locale }}/search/jobs"{% if cb_is_job_search == 'true' %} class="active"{% endif %}>{{ text_header_nav_5 }}</a></li>
                                                </ul>
                                            </nav>
                                        </div>
                                        <div class="columns large-2 header__language">
                                            <div class="header__language-inner">
                                                <button class="header__language-select-js show-for-large">
