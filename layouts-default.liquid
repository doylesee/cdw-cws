                                                    <li><a href="/{{ current_locale.locale }}/pages/why-cdw"{% if page.permalink == 'why-cdw' %} class="active"{% endif %}>{{ text_header_nav_2 }}</a></li>
                                                    <li><a href="/{{ current_locale.locale }}/pages/who-we-are"{% if page.permalink == 'who-we-are' %} class="active"{% endif %}>{{ text_header_nav_3 }}</a></li>
