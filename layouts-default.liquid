{%- endcomment -%}
{% if page.tag_list contains '-section-' %}
    {% redirect_permanent root_url %}

{% elsif page.tag_list contains '-locale-' %}
    {{ page.tags | where: '-locale-' | assign_to: 'page_locale_tag' }}

    {% for locale in available_locales %}
        {% capture locale_down %}-locale-{{ locale.locale | downcase }}{% endcapture %}
        {% if page.tag_list contains locale_down %}
            {% capture page_redirect_url %}/{{ current_locale.locale }}/pages/{{ page_locale_tag[0] | remove: locale_down }}{% endcapture %}
            {% redirect_permanent page_redirect_url %}
        {% endif %}
    {% endfor %}

{% endif %}
<!doctype html>
<html class="no-js" lang="{{ current_locale.locale }}">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta http-equiv="X-UA-Compatible" content="IE=Edge,chrome=1">
        
        <link rel="shortcut icon" type="image/x-icon" href="/system/production/assets/468257/original/cdw__icon.png">
        <link rel="stylesheet" href="https://dhbhdrzi4tiry.cloudfront.net/cdn/sites/foundation.min.css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

        <!--Fonts-->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&family=Source+Sans+3:ital,wght@0,200..900;1,200..900&display=swap" rel="stylesheet">

        <script src="https://code.jquery.com/jquery-3.5.1.min.js" integrity="sha256-9/aliU8dGd2tb6OSsuzixeV4y/faTqgFtohetphbbj0=" crossorigin="anonymous"></script>
        {% careersites_required_head_tags %}
        <script>var $cs = $;</script>

        {% include '__global__config__reusable-texts' %}
        {% include '/__global__config__variables' %}

        <!--SEO Meta Content Logic-->
        <title>{{ meta_title }}</title>

        {% if seo_to_index == 'true' %}
            {% if root_url contains 'preview' or root_url contains '-dev' %}
                <meta name="robots" content="noindex, nofollow">
            {% else %}
                {% if job %}
                    <meta name="robots" content="index, nofollow">
                {% else %}
                    <meta name="robots" content="index, follow">
                {% endif %}
            {% endif %}
        {% else %}
            <meta name="robots" content="noindex, nofollow">
        {% endif %}

        {% capture current_url_with_current_locale_permalink %}{{ request_host_with_port }}{{ locale_permalink }}{% endcapture %}
        {% capture current_url %}https://{{ request_host_with_port }}{{ request_path }}{% endcapture %}
        {% capture canonical_url %}{{ current_url | replace: current_url_with_current_locale_permalink,request_host_with_port }}{% endcapture %}
        <link rel="canonical" href="{{ canonical_url }}" />

        {% for locale in available_locales %}
            {% capture current_url_with_locale_permalink %}{{ request_host_with_port }}/{{ locale.locale }}{% endcapture %}
            {% capture locale_canonical_url %}{{ canonical_url | replace: request_host_with_port,current_url_with_locale_permalink }}{% endcapture %}
            <link href="{{ locale_canonical_url }}" hreflang="{{ locale.locale }}" rel="alternate" type="text/html"/>
        {% endfor %}

        {% if meta_description != blank %}
            <meta name="description" content="{{ meta_description }}">
        {% endif %}
        {%- comment -%}
        {% if meta_keywords != blank %}
            <meta name="keywords" content="{{ meta_keywords }}">
        {% endif %}
        Removed because meta keywords are outdated, irrelevant and has no impact on search engine rankings; and could even hurt SEO
        {%- endcomment -%}
        <!--END SEO Meta Content Logic-->

        <meta property="og:title" content="{{ meta_title }}" />
        <meta property="og:type" content="website" />
        <meta property="og:image" content="{{ root_url }}system/production/assets/468259/original/cdw__social-share.jpg" />
        <meta property="og:url" content="{{ root_url }}{{ request_fullpath | remove_first: '/' }}" />
        {% if meta_description != blank %}<meta property="og:description" content="{{ meta_description }}" />{% endif %}
        <meta property="og:locale" content="{% if current_locale.locale != blank %}{{ current_locale.locale }}{% else %}en{% endif %}" />
        <meta property="og:site_name" content="{{ career_site.name }}" />

        {%- comment -%}Logic for Prod only code{%- endcomment -%}
        {% if root_url contains 'preview' or root_url contains '-dev' %}
            {% capture is_dev %}true{% endcapture %}
        {% endif %}
        {% if is_dev != 'true' %}
            {%- comment -%}Prod only code here{%- endcomment -%}
            {% include '/__global__scripts--head' %}
        {% endif %}
    </head>
    <body id="{% if cb_is_home_page == 'true' %}career_site_home_page{% else %}{{ template.permalink }}{% endif %}" class="scroll">
        {% if is_dev != 'true' %}
            {%- comment -%}Prod only code here{%- endcomment -%}
            {% include '/__global__scripts--body' %}
        {% endif %}

        <div class="hide">
            {% capture returnurl %}return_url\":\"http:\\\\\\\\\\\\\\\\{{career_site.domain}}/\"{% endcapture %}
            {% capture tn %}
              {{ "Join our Talent Network" | link_to_talent_network: "talent-network-main", "talent-network-main" }}
            {% endcapture %}
            {{ tn | replace: 'return_url\":null', returnurl }}
        </div>

        <div class="width-detector"></div>
        <div class="locale-detector-js hide">{{ current_locale.locale }}</div>

        {% if cookies_unsafe['c_first'] == blank and cookies_unsafe['c_allow'] == blank  %}
            <script>document.cookie = 'c_first=1;expires=';</script>
            <div id="cookie-permission" class="hide-for-print padded-v-medium background-7">
                <div class="row">
                    <div class="columns medium-9">
                        {{ text_cookie_copy }}
                    </div>
                    <div class="columns medium-3 text-center">
                      <span class="cookie"><a href="javascript:void(0);" class="cookie-permission-js branded-button-medium" aria-label="Accept Cookies">{{ text_cookie_button }}</a></span>
                    </div>
                </div>
            </div><!--close #cookie-permission-->
        {% endif %}

        <div class="saved-jobs-alert-wrapper full-height full-width hide-for-print" role="alert">
            <div class="saved-jobs-alert">
                <div class="saved-jobs-alert__check padded-medium">
                    <i class="fa fa-circle-check" aria-hidden="true"></i>
                </div>
                <div class="saved-jobs-alert__message padded-medium"></div>
            </div><!--close .saved-jobs-alert-->
        </div><!--close .saved-jobs-alert-wrapper-->

