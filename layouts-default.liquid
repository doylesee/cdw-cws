                                                    <input type="text" placeholder="{{ text_keyword_placeholder_mobile }}" id="cs_jobsearchforminput_keyword" class="ui-autocomplete-input" autocomplete="off" name="q" value="{{ params['q'] | escape_html }}"><span role="status" aria-live="polite" class="ui-helper-hidden-accessible"></span>
                                                    <input type="submit" value="&#xf002;" class="fontawesome" />
                                                </div>
                                            </div>
                                        </form>
                                    </div><!--close .cs_item_type_jobsearch.cs_cfix cs_jsearchform-->
                                </div>
                            </div>
