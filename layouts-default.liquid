                                                            </span>
                                                        {% else %}
                                                            <a href="{{ locale.url }}" class="header__language-item">
                                                                <span class="hide-for-large">{{ locale.locale }}</span>
                                                                <span class="show-for-large">{{ locale.label }}</span>
                                                            </a>
                                                        {% endif %}
                                                    {% endfor %}
                                                </span>
