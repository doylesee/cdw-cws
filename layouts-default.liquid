                                        <div class="columns hide-for-large">
                                            <div class="cs_item_type_jobsearch cs_cfix cs_jsearchform">
                                                <form id="search-form--header-nav" method="get" action="/{{ current_locale.locale }}/search/jobs" class="search-form">
                                                    <div class="row">
                                                        <div class="columns">
                                                            <label for="cs_jobsearchforminput_keyword" class="show-for-sr">{{ text_keyword_placeholder_mobile }}</label>
